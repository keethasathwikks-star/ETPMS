# Root gitignore for ETPMS monorepo

# Python
*.pyc
__pycache__/
*.pyo
*.pyd
.env
venv/
.env.*
.pytest_cache/

# Node
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
npm-shrinkwrap.json
!FRONTEND/eptms/package-lock.json
FRONTEND/eptms/node_modules.zip

# Java
target/
*.log
*.class
*.jar
*.war

# IDE
.vscode/
.idea/
*.iml

# macOS
.DS_Store

# Misc
*.tmp
*.swp
*~
